{
  "expo": {
    "name": "AgriAI",
    "slug": "agriai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "agriai",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agriai.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "AgriAI uses your location to provide local weather and crop recommendations.",
        "NSCameraUsageDescription": "AgriAI uses your camera to capture crop photos for disease detection.",
        "NSPhotoLibraryUsageDescription": "AgriAI needs gallery access to pick crop photos for disease detection."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.agriai.app",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "AgriAI uses your location for weather and crop recommendations."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "AgriAI needs gallery access to pick crop photos for disease detection.",
          "cameraPermission": "AgriAI needs camera access to capture crop photos for disease detection."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-notifications",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fd995d80-a010-4cee-b7a7-54ef0f59ed1f"
      }
    }
  }
}
